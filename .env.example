# ── Instance ──────────────────────────────────────────────────────────────────
# Your domain name (no protocol, no trailing slash)
DOMAIN=yourdomain.com

# Full URL used in emails, federation, etc.
INSTANCE_DOMAIN=https://yourdomain.com

INSTANCE_NAME=Agora

# ── SSL ───────────────────────────────────────────────────────────────────────
# Set to true once you have run setup-ssl.sh and obtained a certificate.
# false = serve plain HTTP on port 80 (useful for local/dev or behind a load balancer)
SSL_ENABLED=false

# ── Auth — CHANGE THIS in production ─────────────────────────────────────────
# Generate with:  openssl rand -hex 64
JWT_SECRET=changeme-use-a-very-long-random-string-in-production

# ── Database — matches docker-compose defaults ────────────────────────────────
DATABASE_URL=postgres://agora:agora@postgres:5432/agora?sslmode=disable

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=/data/uploads

# ── Email (SMTP) — can also be configured in the Admin Panel ──────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
SMTP_ENABLED=false

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=production
