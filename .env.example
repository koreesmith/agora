# ── Server ────────────────────────────────────────────────────────────────────
HTTP_ADDR=:8080
INSTANCE_DOMAIN=http://localhost
INSTANCE_NAME=Agora

# ── Auth — CHANGE THIS in production (use: openssl rand -hex 64) ─────────────
JWT_SECRET=changeme-use-a-very-long-random-string-in-production

# ── Postgres — matches docker-compose defaults ────────────────────────────────
DATABASE_URL=postgres://agora:agora@postgres:5432/agora?sslmode=disable

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=/data/uploads

# ── Email (SMTP) — configure in Admin Panel after first login ─────────────────
# These can also be set here as defaults
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@localhost
SMTP_ENABLED=false

# ── Environment ───────────────────────────────────────────────────────────────
# development | production
ENVIRONMENT=production

# ── Federation ────────────────────────────────────────────────────────────────
# Set to true in admin panel — not recommended to set here directly
# FEDERATION_ENABLED=false
